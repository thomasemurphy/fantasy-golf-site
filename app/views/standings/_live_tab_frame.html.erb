<%# Live tab body, wrapped in a Turbo Frame so sorting re-renders only this
    fragment (via StandingsController#tab) instead of reloading the whole page.
    Sort headers carry live_sub so the active Pool/All-Golfers sub-view survives a sort. %>
    <% live_base_pool  = { tab: "live", live_sub: "pool" } %>
    <% live_base_field = { tab: "live", live_sub: "field" } %>
    <% cur_sort  = (@initial_tab == "live" ? @sort : nil) || "earnings"; cur_dir = (@initial_tab == "live" ? @dir : nil) || "desc" %>
    <% on_cooldown = @last_refreshed && Time.current - @last_refreshed < StandingsController::REFRESH_COOLDOWN %>
    <%# The final major of the season: show the season Pos/Earnings columns as
        Majors-pot standings instead, so the pool can watch the majors race live. %>
    <% majors_week = @live_tournament.tournament_type == "major" %>

    <turbo-frame id="tab-live" class="tab-pane fade <%= 'show active' if @initial_tab == 'live' %>" role="tabpanel">
      <div class="live-standings-outer">
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
          <div class="d-flex align-items-center gap-2">
            <h5 class="mb-0"><%= @live_tournament.name %></h5>
            <span class="badge bg-success">In Progress</span>
          </div>
          <div class="d-flex align-items-center gap-3 ms-auto flex-wrap">
            <% if @last_refreshed %>
              <span class="text-muted refreshed-label" style="font-size:12px" data-refreshed-at="<%= @last_refreshed.to_i %>"></span>
            <% end %>
            <a href="<%= refresh_standings_path(return_tab: 'live', live_sub: @initial_live_sub) %>"
               class="btn btn-sm btn-outline-success<%= ' disabled' if on_cooldown %>"
               id="refresh-btn"
               data-turbo="false">↻ Refresh</a>
            <div class="btn-group btn-group-sm pool-field-toggle" role="group">
              <button class="btn btn-outline-secondary <%= 'active' if @initial_live_sub != 'field' %>"
                      data-bs-toggle="tab" data-bs-target="#live-pool" type="button">Pool Players</button>
              <button class="btn btn-outline-secondary <%= 'active' if @initial_live_sub == 'field' %>"
                      data-bs-toggle="tab" data-bs-target="#live-field" type="button">All Golfers</button>
            </div>
          </div>
        </div>

        <div class="tab-content">
          <%# Pool view %>
          <div id="live-pool" class="tab-pane <%= 'show active' if @initial_live_sub != 'field' %>">
            <% if @live_pool_standings.empty? %>
              <div class="alert alert-info">Live scores not yet available — check back soon.</div>
            <% else %>
              <% live_max_total = @live_pool_standings.map { |r| r[:total_earnings_cents].to_i }.max || 1 %>
              <div class="standings-table-wrapper" style="width:100%">
                <table class="standings-table">
                  <thead>
                    <tr>
                      <th>Rank</th>
                      <th><%= sort_header("Player",         "player",   live_base_pool, cur_sort, cur_dir) %></th>
                      <% if majors_week %>
                        <th class="text-center"><%= sort_header("Pos", "season", live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                        <th class="text-center"><%= sort_header("Majors Pos", "majors", live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                        <th style="text-align:right;padding-left:4px;padding-right:8px"><%= sort_header("Majors $", "majors", live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <% else %>
                        <th class="text-center">Pos</th>
                        <th style="text-align:right;padding-left:4px;padding-right:8px"><%= sort_header("Earnings", "season", live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <% end %>
                      <th style="padding-left:48px;padding-right:0"><%= sort_header("Golfer",         "golfer",   live_base_pool, cur_sort, cur_dir) %></th>
                      <th class="text-center" style="padding-left:0"><%= sort_header("Pos",    "pos",      live_base_pool, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Score",  "score",    live_base_pool, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Thru",   "thru",     live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <th class="text-end"><%= sort_header("Proj. Earnings", "earnings", live_base_pool, cur_sort, cur_dir, natural_dir: "desc") %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @live_pool_standings.each do |row| %>
                      <tr class="<%= 'highlight' if row[:user] == current_user %><%= ' cut-row' if row[:position_display] == 'CUT' %><%= ' wd-row' if row[:position_display] == 'WD' %><%= ' auto-pick-row' if row[:pick]&.auto_assigned? %>">
                        <td><span class="standings-rank"><%= row[:rank] %></span></td>
                        <td>
                          <%= render "standings/player_tooltip", row: row, pool_max_total: live_max_total, pool_size: @live_pool_standings.size %>
                        </td>
                        <% if majors_week %>
                          <td class="text-center tabular-nums"><%= row[:overall_rank] %></td>
                        <% end %>
                        <td class="text-center tabular-nums"><%= majors_week ? row[:majors_rank] : row[:overall_rank] %></td>
                        <td class="tabular-nums" style="text-align:right;padding-left:4px;padding-right:8px">
                          <% row_total = majors_week ? row[:total_majors_earnings_cents] : row[:total_earnings_cents] %>
                          <% if row_total.to_i > 0 %>
                            <%= abbreviated_earnings(row_total) %>
                          <% else %>
                            <span class="text-muted">$0.0m</span>
                          <% end %>
                        </td>
                        <td style="padding-left:48px;padding-right:0">
                          <%= render "standings/golfer_tooltip", golfer: row[:golfer], golfer_history: row[:golfer_history], pairings: @live_pairings %>
                          <% if row[:pick].is_double_down? %><span class="badge bg-warning text-dark ms-1">2x</span><% end %>
                          <% if row[:pick].auto_assigned? %><span class="badge bg-secondary ms-1">Auto</span><% end %>
                        </td>
                        <% has_started = !(row[:round] == 1 && !(row[:thru]&.match?(/\A\d+\z/) || row[:thru] == "F")) %>
                        <td class="text-center" style="padding-left:0"><%= (has_started && row[:position_display] != "CUT") ? (row[:position_display].presence || "—") : "—" %></td>
                        <td class="text-center"><%= (has_started && row[:position_display] != "WD") ? format_score(row[:score_to_par]) : "—" %></td>
                        <td class="text-center"><%= row[:position_display] == "CUT" ? "CUT" : (row[:position_display] == "WD" ? "—" : live_thru_cell(row[:thru], row[:round])) %></td>
                        <td class="text-end">
                          <% # has_started computed above %>
                          <% if row[:pick].auto_assigned? %>
                            <span class="text-muted">$0</span>
                          <% elsif row[:position_display] == 'WD' || !has_started %>
                            <span class="text-muted">—</span>
                          <% elsif row[:current_earnings_cents]&.positive? %>
                            $<%= number_with_delimiter((row[:current_earnings_cents] / 100.0).to_i) %>
                          <% else %>
                            <span class="text-muted">—</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>

          <%# Field view %>
          <div id="live-field" class="tab-pane <%= 'show active' if @initial_live_sub == 'field' %>">
            <% if @live_field_standings.empty? %>
              <div class="alert alert-info">Live scores not yet available — check back soon.</div>
            <% else %>
              <% live_pool_max_total   = @live_pool_standings.map { |r| r[:total_earnings_cents].to_i }.max || 1 %>
              <% live_pool_row_by_user = @live_pool_standings.index_by { |r| r[:user].id } %>
              <div class="standings-table-wrapper" style="width:100%">
                <table class="standings-table">
                  <thead>
                    <tr>
                      <th><%= sort_header("Pos",    "pos",    live_base_field, cur_sort, cur_dir) %></th>
                      <th><%= sort_header("Golfer", "golfer", live_base_field, cur_sort, cur_dir) %></th>
                      <th><%= sort_header("Score",  "score",  live_base_field, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Thru", "thru", live_base_field, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <th class="text-end">Proj $</th>
                      <th>Picked By</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @live_field_standings.each do |row| %>
                      <% picked_by_me = row[:picks].any? { |p| p.user == current_user } %>
                      <% field_started = !(row[:round] == 1 && !(row[:thru]&.match?(/\A\d+\z/) || row[:thru] == "F")) %>
                      <tr class="<%= 'highlight' if picked_by_me %><%= ' cut-row' if row[:position_display] == 'CUT' %>">
                        <td class="text-center"><%= (field_started && row[:position_display] != "CUT") ? (row[:position_display].presence || "—") : "—" %></td>
                        <td>
                          <%= render "standings/golfer_tooltip", golfer: row[:golfer], golfer_history: row[:golfer_history], pairings: @live_pairings %>
                        </td>
                        <td class="text-center"><%= field_started ? format_score(row[:score_to_par]) : "—" %></td>
                        <td class="text-center"><%= row[:position_display] == "CUT" ? "CUT" : live_thru_cell(row[:thru], row[:round]) %></td>
                        <td class="text-end">
                          <% if !field_started || row[:position_display].in?(%w[CUT WD]) %>
                            <span class="text-muted">—</span>
                          <% elsif row[:current_earnings_cents]&.positive? %>
                            $<%= number_with_delimiter((row[:current_earnings_cents] / 100.0).to_i) %>
                          <% else %>
                            <span class="text-muted">—</span>
                          <% end %>
                        </td>
                        <td class="text-muted" style="font-size:0.875em">
                          <% row[:picks].each_with_index do |pick, i| %>
                            <% pool_row = live_pool_row_by_user[pick.user_id] %>
                            <% if pool_row %><%= render "standings/player_tooltip", row: pool_row, pool_max_total: live_pool_max_total, pool_size: @live_pool_standings.size %><% else %><%= pick.user.name %><% end %><% if pick.is_double_down? %>&nbsp;<span class="badge bg-warning text-dark">2x</span><% end %><%= i < row[:picks].size - 1 ? ", " : "" %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>
        </div><%# inner tab-content %>
      </div><%# live-standings-outer %>
    </turbo-frame><%# #tab-live %>

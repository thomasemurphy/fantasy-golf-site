<%# Renders a pool player's name with the season pick-history tooltip.
    Locals:   row, pool_max_total, pool_size
    Optional: rank (defaults to overall_rank || rank), live_pick (defaults to nil)

    By default the tooltip shows only second-half tournaments (weeks 14+) plus the
    live pick. First-half weeks collapse behind a "Show more" toggle that unfurls on hover. %>
<% rank      = local_assigns.fetch(:rank, row[:overall_rank] || row[:rank]) %>
<% live_pick = local_assigns.fetch(:live_pick, nil) %>
<% completed = row[:completed_picks] || [] %>
<% if completed.any? || live_pick %>
  <% ttl = row[:total_earnings_cents].to_i %>
  <% rh  = rank_hue(rank, pool_size) %>
  <% eh  = earnings_hue(ttl, pool_max_total) %>
  <% first_half  = completed.select { |cp| cp[:pick].tournament.week_number <= 13 } %>
  <% second_half = completed.select { |cp| cp[:pick].tournament.week_number >= 14 } %>
  <%# Default-visible group is the second half (plus live pick); collapse the first half.
      If there is no second half yet, show the first half outright with no toggle. %>
  <% if second_half.any? || live_pick %>
    <% visible_picks = second_half %><% collapsed_picks = first_half %>
  <% else %>
    <% visible_picks = first_half %><% collapsed_picks = [] %>
  <% end %>
  <span data-controller="tooltip"
        data-tooltip-title-value="<%= row[:user].name %>"
        data-tooltip-rank-value="<%= rank %>"
        <% if rh %>data-tooltip-rank-hue-value="<%= rh %>"<% end %>
        <% if ttl > 0 %>data-tooltip-earnings-value="$<%= number_with_delimiter((ttl / 100.0).to_i) %>"<% end %>
        <% if eh %>data-tooltip-earnings-hue-value="<%= eh %>"<% end %>>
    <span data-tooltip-target="trigger"
          data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
          class="pick-history-name"><%= row[:user].name %></span>
    <span data-tooltip-target="content" style="display:none">
      <table style="border-spacing:0;line-height:1.9">
        <% if collapsed_picks.any? %>
          <tbody class="ph-expand">
            <tr class="ph-more-row"><td colspan="5">Show more ▾</td></tr>
            <% collapsed_picks.each do |cp| %>
              <%= pick_history_tooltip_row(cp, hidden: true) %>
            <% end %>
          </tbody>
        <% end %>
        <tbody class="ph-second">
          <% visible_picks.each do |cp| %>
            <%= pick_history_tooltip_row(cp) %>
          <% end %>
          <% if live_pick %>
            <% lp_pick = live_pick[:pick] %>
            <tr style="color:#5b8dd9;font-style:italic">
              <td style="color:#7aaae8;padding-right:10px;white-space:nowrap">Wk<%= lp_pick.tournament.week_number %></td>
              <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(lp_pick.tournament.name) %></td>
              <td style="padding-right:12px;white-space:nowrap">
                <%= lp_pick.golfer.name %>
                <% if lp_pick.is_double_down? %><span style="color:#b8a830;font-size:10px;font-weight:600;font-style:normal">2x</span><% end %>
                <% if lp_pick.auto_assigned? %><span style="color:#7aaae8;font-size:10px">(auto)</span><% end %>
              </td>
              <td style="padding-right:12px;white-space:nowrap"><%= live_pick[:position] || "—" %></td>
              <td style="text-align:right;white-space:nowrap">live</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </span>
  </span>
<% else %>
  <%= row[:user].name %>
<% end %>

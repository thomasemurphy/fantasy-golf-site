<% no_cut_alive_ids = @no_cut_users.map(&:id).to_set %>
<% dd_min = standings.map { |r| r[:user].double_downs_remaining }.min %>
<% scoped = @initial_tab == tab_id %>
<% cur_sort = (scoped ? @sort : nil) || "earnings"; cur_dir = (scoped ? @dir : nil) || "desc" %>
<% s_base = { tab: tab_id } %>
<div class="standings-table-wrapper">
  <table class="standings-table">
    <thead>
      <tr>
        <th>Rank</th>
        <th><%= sort_header("Player",   "player", s_base, cur_sort, cur_dir) %></th>
        <th class="text-end"><%= sort_header("Earnings", "earnings", s_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
        <th class="text-center"><%= sort_header("2x Left", "dd",     s_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
        <th class="text-center"><%= sort_header("No-Cut",  "nocut",  s_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
      </tr>
    </thead>
    <tbody>
      <% standings.each do |row| %>
        <tr class="<%= 'highlight' if row[:user] == current_user %>">
          <td><span class="standings-rank"><%= row[:rank] %></span></td>
          <td>
            <% if row[:completed_picks].any? %>
              <% ttl = row[:total_earnings_cents].to_i %>
              <span data-controller="tooltip"
                    data-tooltip-title-value="<%= row[:user].name %>"
                    data-tooltip-rank-value="<%= row[:rank] %>"
                    <% if ttl > 0 %>data-tooltip-earnings-value="$<%= number_with_delimiter((ttl / 100.0).to_i) %>"<% end %>>
                <span data-tooltip-target="trigger"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
                      class="pick-history-name"><%= row[:user].name %></span>
                <span data-tooltip-target="content" style="display:none">
                  <table style="border-spacing:0;line-height:1.9">
                    <% row[:completed_picks].each do |cp| %>
                      <% pick = cp[:pick] %>
                      <tr>
                        <td style="color:#aaa;padding-right:10px;white-space:nowrap">Wk<%= pick.tournament.week_number %></td>
                        <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(pick.tournament.name) %></td>
                        <td style="padding-right:12px;white-space:nowrap">
                          <%= pick.golfer.name %>
                          <% if pick.is_double_down? %><span style="color:#b8860b;font-size:10px;font-weight:600">2x</span><% end %>
                          <% if pick.auto_assigned? %><span style="color:#aaa;font-size:10px">(auto)</span><% end %>
                        </td>
                        <td style="padding-right:12px;white-space:nowrap;color:#6c757d"><%= cp[:position] || "—" %></td>
                        <td style="text-align:right;white-space:nowrap">
                          <% if pick.auto_assigned? %>
                            <span style="color:#aaa">$0</span>
                          <% elsif pick.earnings_cents.to_i > 0 %>
                            $<%= number_with_delimiter((pick.earnings_cents / 100.0).to_i) %>
                          <% else %>
                            <span style="color:#aaa">$0</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </table>
                </span>
              </span>
            <% else %>
              <%= row[:user].name %>
            <% end %>
          </td>
          <td class="text-end tabular-nums">
            <% if row[:earnings_cents] %>
              $<%= number_with_delimiter((row[:earnings_cents] / 100.0).to_i) %>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </td>
          <% dd = row[:user].double_downs_remaining %>
          <% dd_hue = dd_min == 5 ? 120 : ((dd - dd_min).to_f / (5 - dd_min) * 120).round %>
          <td class="text-center" style="color: hsl(<%= dd_hue %>, 65%, 42%); font-weight: 600"><%= dd %></td>
          <td class="text-center">
            <% if no_cut_alive_ids.include?(row[:user].id) %>
              <span class="text-success fw-semibold">Still alive</span>
            <% else %>
              <span style="color: #a0522d;">🍞 Toast</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

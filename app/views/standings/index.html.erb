<% if @live_tournament %>
  <meta http-equiv="refresh" content="300">
<% end %>

<%# === NAV ROW 1: season-level tabs === %>
<ul class="nav nav-pills mb-2" id="mainTabs" role="tablist">
  <% if @live_tournament %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if @initial_tab == 'live' %>"
              data-bs-toggle="tab" data-bs-target="#tab-live" type="button" role="tab">
        <span class="text-danger fw-bold">&#9679;</span> Live
      </button>
    </li>
  <% end %>
  <% [["overall","Main Pot","tab-label-regular","~60% of total pot, ~$6,700","All events"],["majors","Majors Pot","tab-label-major","15% of total pot, ~$1,600",nil],["side_events","High-Purse Side Pot","tab-label-side-event","15% of total pot, ~$1,600",nil],["pink_events","Low-Purse Side Pot","tab-label-pink-event","$500",nil],["first_half","🕐 1st Half","tab-label-first-half","$300",nil],["second_half","🕢 2nd Half","tab-label-second-half","$300",nil]].each do |tid, label, css_class, prize_text, body_text| %>
    <% pot_tourneys = @pot_tournaments[tid] %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= 'active' if @initial_tab == tid %>"
              data-bs-toggle="tab" data-bs-target="#tab-<%= tid %>" type="button" role="tab">
        <% if prize_text %>
          <span data-controller="tooltip" data-tooltip-position-value="below">
            <span data-tooltip-target="trigger"
                  data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
                  class="<%= css_class %>"><%= label %></span>
            <span data-tooltip-target="content" style="display:none">
              <div style="color:#aaa;font-style:italic;margin-bottom:4px"><%= prize_text %></div>
              <% if pot_tourneys %>
                <table style="border-spacing:0;line-height:1.9">
                  <% pot_tourneys.each do |t| %>
                    <% d1 = t.start_date; d2 = t.end_date %>
                    <% dates = d1.month == d2.month ? "#{d1.strftime('%b %-d')}-#{d2.strftime('%-d')}" : "#{d1.strftime('%b %-d')}-#{d2.strftime('%b %-d')}" %>
                    <tr>
                      <td style="color:#aaa;padding-right:10px;white-space:nowrap">Wk&nbsp;<%= t.week_number %></td>
                      <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(t.name) %></td>
                      <td style="white-space:nowrap;color:#6c757d"><%= dates %></td>
                    </tr>
                  <% end %>
                </table>
              <% elsif body_text %>
                <div style="color:#6c757d;margin-top:2px"><%= body_text %></div>
              <% end %>
            </span>
          </span>
        <% elsif css_class %>
          <span class="<%= css_class %>"><%= label %></span>
        <% else %>
          <%= label %>
        <% end %>
      </button>
    </li>
  <% end %>
</ul>

<%# === NAV ROW 2: per-tournament week tabs === %>
<% if @completed_tournaments.any? %>
  <ul class="nav nav-pills nav-pills-sm flex-wrap mb-4" id="weekTabs" role="tablist">
    <% type_class = { "regular" => "tab-label-regular", "major" => "tab-label-major", "side_event" => "tab-label-side-event", "pink_event" => "tab-label-pink-event" } %>
    <% @completed_tournaments.each do |t| %>
      <% target = t.status == "in_progress" ? "tab-live" : "tab-t#{t.id}" %>
      <% active  = t.status == "in_progress" ? @initial_tab == "live" : @initial_tab == "t#{t.id}" %>
      <% name_class = type_class[t.tournament_type] %>
      <li class="nav-item" role="presentation">
        <button class="nav-link nav-link-sm <%= 'active' if active %>"
                data-bs-toggle="tab" data-bs-target="#<%= target %>" type="button" role="tab">
          <span class="text-muted fw-normal me-1" style="font-size:0.7em">Wk&nbsp;<%= t.week_number %></span><% if name_class %><span class="<%= name_class %>"><%= t.name %></span><% else %><%= t.name %><% end %>
        </button>
      </li>
    <% end %>
  </ul>
<% end %>

<%# === ALL TAB CONTENT === %>
<div class="tab-content">

  <%# --- Live tab --- %>
  <% if @live_tournament %>
    <% live_base = { tab: "live" } %>
    <% cur_sort  = (@initial_tab == "live" ? @sort : nil) || "earnings"; cur_dir = (@initial_tab == "live" ? @dir : nil) || "desc" %>
    <% on_cooldown = @last_refreshed && Time.current - @last_refreshed < StandingsController::REFRESH_COOLDOWN %>

    <div id="tab-live" class="tab-pane fade <%= 'show active' if @initial_tab == 'live' %>" role="tabpanel">
      <div class="live-standings-outer">
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
          <div class="d-flex align-items-center gap-2">
            <h5 class="mb-0"><%= @live_tournament.name %></h5>
            <span class="badge bg-success">In Progress</span>
          </div>
          <div class="d-flex align-items-center gap-3 ms-auto flex-wrap">
            <% if @last_refreshed %>
              <span class="text-muted refreshed-label" style="font-size:12px" data-refreshed-at="<%= @last_refreshed.to_i %>"></span>
            <% end %>
            <%= button_to refresh_standings_path, method: :post,
                  class: "btn btn-sm btn-outline-success #{'disabled' if on_cooldown}",
                  disabled: on_cooldown,
                  id: "refresh-btn",
                  form: { id: "refresh-form", data: { turbo: false } } do %>
              <input type="hidden" name="return_tab" id="refresh-return-tab" value="live">
              <input type="hidden" name="live_sub" id="refresh-live-sub" value="pool">
              ↻ Refresh
            <% end %>
            <div class="btn-group btn-group-sm pool-field-toggle" role="group">
              <button class="btn btn-outline-secondary <%= 'active' if @initial_live_sub != 'field' %>"
                      data-bs-toggle="tab" data-bs-target="#live-pool" type="button">Pool Players</button>
              <button class="btn btn-outline-secondary <%= 'active' if @initial_live_sub == 'field' %>"
                      data-bs-toggle="tab" data-bs-target="#live-field" type="button">All Golfers</button>
            </div>
          </div>
        </div>

        <div class="tab-content">
          <%# Pool view %>
          <div id="live-pool" class="tab-pane <%= 'show active' if @initial_live_sub != 'field' %>">
            <% if @live_pool_standings.empty? %>
              <div class="alert alert-info">Live scores not yet available — check back soon.</div>
            <% else %>
              <div class="standings-table-wrapper" style="width:100%">
                <table class="standings-table">
                  <thead>
                    <tr>
                      <th>Rank</th>
                      <th><%= sort_header("Player",         "player",   live_base, cur_sort, cur_dir) %></th>
                      <th><%= sort_header("Golfer",         "golfer",   live_base, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Pos",    "pos",      live_base, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Score",  "score",    live_base, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Thru",   "thru",     live_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <th class="text-end"><%= sort_header("Proj. Earnings", "earnings", live_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @live_pool_standings.each do |row| %>
                      <tr class="<%= 'highlight' if row[:user] == current_user %><%= ' cut-row' if row[:position_display] == 'CUT' %><%= ' wd-row' if row[:position_display] == 'WD' %><%= ' auto-pick-row' if row[:pick]&.auto_assigned? %>">
                        <td><span class="standings-rank"><%= row[:rank] %></span></td>
                        <td>
                          <% if row[:completed_picks].any? %>
                            <% ttl = row[:total_earnings_cents].to_i %>
                            <span data-controller="tooltip"
                                  data-tooltip-title-value="<%= row[:user].name %>"
                                  data-tooltip-rank-value="<%= row[:overall_rank] %>"
                                  <% if ttl > 0 %>data-tooltip-earnings-value="$<%= number_with_delimiter((ttl / 100.0).to_i) %>"<% end %>>
                              <span data-tooltip-target="trigger"
                                    data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
                                    class="pick-history-name"><%= row[:user].name %></span>
                              <span data-tooltip-target="content" style="display:none">
                                <table style="border-spacing:0;line-height:1.9">
                                  <% row[:completed_picks].each do |cp| %>
                                    <% pick = cp[:pick] %>
                                    <tr>
                                      <td style="color:#aaa;padding-right:10px;white-space:nowrap">Wk<%= pick.tournament.week_number %></td>
                                      <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(pick.tournament.name) %></td>
                                      <td style="padding-right:12px;white-space:nowrap">
                                        <%= pick.golfer.name %>
                                        <% if pick.is_double_down? %><span style="color:#b8860b;font-size:10px;font-weight:600">2x</span><% end %>
                                        <% if pick.auto_assigned? %><span style="color:#aaa;font-size:10px">(auto)</span><% end %>
                                      </td>
                                      <td style="padding-right:12px;white-space:nowrap;color:#6c757d"><%= cp[:position] || "—" %></td>
                                      <td style="text-align:right;white-space:nowrap">
                                        <% if pick.auto_assigned? %>
                                          <span style="color:#aaa">$0</span>
                                        <% elsif pick.earnings_cents.to_i > 0 %>
                                          $<%= number_with_delimiter((pick.earnings_cents / 100.0).to_i) %>
                                        <% else %>
                                          <span style="color:#aaa">$0</span>
                                        <% end %>
                                      </td>
                                    </tr>
                                  <% end %>
                                </table>
                              </span>
                            </span>
                          <% else %>
                            <%= row[:user].name %>
                          <% end %>
                        </td>
                        <td>
                          <% gh = row[:golfer_history] %>
                          <% if gh.any? { |e| e[:result] } %>
                            <% golfer_earnings = gh.sum { |e| e[:result]&.earnings_cents.to_i } %>
                            <span data-controller="tooltip"
                                  data-tooltip-title-value="<%= row[:golfer].name %>"
                                  <% if golfer_earnings > 0 %>data-tooltip-earnings-value="$<%= number_with_delimiter((golfer_earnings / 100.0).to_i) %>"<% end %>>
                              <span data-tooltip-target="trigger"
                                    data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
                                    class="pick-history-name"><%= row[:golfer].name %></span>
                              <span data-tooltip-target="content" style="display:none">
                                <table style="border-spacing:0;line-height:1.9">
                                  <% gh.each do |entry| %>
                                    <% res = entry[:result] %>
                                    <tr>
                                      <td style="color:#aaa;padding-right:10px;white-space:nowrap">Wk<%= entry[:tournament].week_number %></td>
                                      <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(entry[:tournament].name) %></td>
                                      <% if res %>
                                        <td style="padding-right:12px;white-space:nowrap;color:#6c757d"><%= res.current_position_display.presence || "—" %></td>
                                        <td style="text-align:right;white-space:nowrap">
                                          <% if res.earnings_cents.to_i > 0 %>
                                            $<%= number_with_delimiter((res.earnings_cents / 100.0).to_i) %>
                                          <% else %>
                                            <span style="color:#aaa">$0</span>
                                          <% end %>
                                        </td>
                                      <% else %>
                                        <td style="padding-right:12px;white-space:nowrap;color:#aaa">—</td>
                                        <td style="text-align:right;white-space:nowrap;color:#aaa">—</td>
                                      <% end %>
                                    </tr>
                                  <% end %>
                                </table>
                              </span>
                            </span>
                          <% else %>
                            <%= row[:golfer].name %>
                          <% end %>
                          <% if row[:pick].is_double_down? %><span class="badge bg-warning text-dark ms-1">2x</span><% end %>
                          <% if row[:pick].auto_assigned? %><span class="badge bg-secondary ms-1">Auto</span><% end %>
                        </td>
                        <% has_started = !(row[:round] == 1 && !(row[:thru]&.match?(/\A\d+\z/) || row[:thru] == "F")) %>
                        <td class="text-center"><%= has_started ? (row[:position_display].presence || "—") : "—" %></td>
                        <td class="text-center"><%= has_started ? format_score(row[:score_to_par]) : "—" %></td>
                        <td class="text-center"><%= row[:thru] == "F" ? "F#{row[:round]}" : (row[:thru].presence || "—") %></td>
                        <td class="text-end">
                          <% # has_started computed above %>
                          <% if row[:pick].auto_assigned? %>
                            <span class="text-muted">$0</span>
                          <% elsif row[:position_display] == 'WD' || !has_started %>
                            <span class="text-muted">—</span>
                          <% elsif row[:current_earnings_cents]&.positive? %>
                            $<%= number_with_delimiter((row[:current_earnings_cents] / 100.0).to_i) %>
                          <% else %>
                            <span class="text-muted">—</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>

          <%# Field view %>
          <div id="live-field" class="tab-pane <%= 'show active' if @initial_live_sub == 'field' %>">
            <% if @live_field_standings.empty? %>
              <div class="alert alert-info">Live scores not yet available — check back soon.</div>
            <% else %>
              <div class="standings-table-wrapper" style="width:100%">
                <table class="standings-table">
                  <thead>
                    <tr>
                      <th><%= sort_header("Pos",    "pos",    live_base, cur_sort, cur_dir) %></th>
                      <th><%= sort_header("Golfer", "golfer", live_base, cur_sort, cur_dir) %></th>
                      <th><%= sort_header("Score",  "score",  live_base, cur_sort, cur_dir) %></th>
                      <th class="text-center"><%= sort_header("Thru", "thru", live_base, cur_sort, cur_dir, natural_dir: "desc") %></th>
                      <th class="text-end">Proj $</th>
                      <th>Picked By</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @live_field_standings.each do |row| %>
                      <% picked_by_me = row[:picks].any? { |p| p.user == current_user } %>
                      <% field_started = !(row[:round] == 1 && !(row[:thru]&.match?(/\A\d+\z/) || row[:thru] == "F")) %>
                      <tr class="<%= 'highlight' if picked_by_me %><%= ' cut-row' if row[:position_display] == 'CUT' %>">
                        <td class="text-center"><%= field_started ? (row[:position_display].presence || "—") : "—" %></td>
                        <td><%= row[:golfer].name %></td>
                        <td class="text-center"><%= field_started ? format_score(row[:score_to_par]) : "—" %></td>
                        <td class="text-center"><%= row[:thru] == "F" ? "F#{row[:round]}" : (row[:thru].presence || "—") %></td>
                        <td class="text-end">
                          <% if !field_started || row[:position_display].in?(%w[CUT WD]) %>
                            <span class="text-muted">—</span>
                          <% elsif row[:current_earnings_cents]&.positive? %>
                            $<%= number_with_delimiter((row[:current_earnings_cents] / 100.0).to_i) %>
                          <% else %>
                            <span class="text-muted">—</span>
                          <% end %>
                        </td>
                        <td class="text-muted" style="font-size:0.875em">
                          <% row[:picks].each_with_index do |pick, i| %>
                            <%= pick.user.name %><% if pick.is_double_down? %>&nbsp;<span class="badge bg-warning text-dark">2x</span><% end %><%= i < row[:picks].size - 1 ? ", " : "" %>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>
        </div><%# inner tab-content %>
      </div><%# live-standings-outer %>
    </div><%# #tab-live %>
  <% end %>

  <%# --- Season standings tabs (Overall, Majors, Side Events, 1st Half, 2nd Half) --- %>

  <%# Overall tab has a Pool Players / All Golfers toggle %>
  <div id="tab-overall" class="tab-pane fade <%= 'show active' if @initial_tab == 'overall' %>" role="tabpanel">
    <div class="standings-table-wrapper">
      <%# Toggle header inside the card %>
      <div class="d-flex justify-content-end p-2 border-bottom">
        <div class="btn-group btn-group-sm pool-field-toggle" role="group">
          <button class="btn btn-outline-secondary active"
                  data-bs-toggle="tab" data-bs-target="#overall-pool" type="button">Pool Players</button>
          <button class="btn btn-outline-secondary"
                  data-bs-toggle="tab" data-bs-target="#overall-golfers" type="button">All Golfers</button>
        </div>
      </div>
      <div class="tab-content">
        <div id="overall-pool" class="tab-pane show active">
          <%= render "season_table", standings: @overall_standings, tab_id: "overall", skip_wrapper: true %>
        </div>
        <div id="overall-golfers" class="tab-pane">
          <table class="standings-table">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Golfer</th>
                <th class="text-end">Season Earnings</th>
              </tr>
            </thead>
            <tbody>
              <% @all_season_golfers.each do |row| %>
                <tr>
                  <td><span class="standings-rank"><%= row[:rank] %></span></td>
                  <td>
                    <% gh = row[:history] %>
                    <% if gh.any? { |e| e[:result] } %>
                      <% total_earnings = row[:earnings_cents] %>
                      <span data-controller="tooltip"
                            data-tooltip-title-value="<%= row[:golfer].name %>"
                            <% if total_earnings > 0 %>data-tooltip-earnings-value="$<%= number_with_delimiter((total_earnings / 100.0).to_i) %>"<% end %>>
                        <span data-tooltip-target="trigger"
                              data-action="mouseenter->tooltip#show mouseleave->tooltip#hide"
                              class="pick-history-name"><%= row[:golfer].name %></span>
                        <span data-tooltip-target="content" style="display:none">
                          <table style="border-spacing:0;line-height:1.9">
                            <% gh.each do |entry| %>
                              <% res = entry[:result] %>
                              <tr>
                                <td style="color:#aaa;padding-right:10px;white-space:nowrap">Wk<%= entry[:tournament].week_number %></td>
                                <td style="padding-right:12px;white-space:nowrap"><%= short_tournament_name(entry[:tournament].name) %></td>
                                <% if res %>
                                  <td style="padding-right:12px;white-space:nowrap;color:#6c757d"><%= res.current_position_display.presence || "—" %></td>
                                  <td style="text-align:right;white-space:nowrap">
                                    <% if res.earnings_cents.to_i > 0 %>
                                      $<%= number_with_delimiter((res.earnings_cents / 100.0).to_i) %>
                                    <% else %>
                                      <span style="color:#aaa">$0</span>
                                    <% end %>
                                  </td>
                                <% else %>
                                  <td style="padding-right:12px;white-space:nowrap;color:#aaa">—</td>
                                  <td style="text-align:right;white-space:nowrap;color:#aaa">—</td>
                                <% end %>
                              </tr>
                            <% end %>
                          </table>
                        </span>
                      </span>
                    <% else %>
                      <%= row[:golfer].name %>
                    <% end %>
                  </td>
                  <td class="text-end tabular-nums">
                    <% if row[:earnings_cents] > 0 %>
                      $<%= number_with_delimiter((row[:earnings_cents] / 100.0).to_i) %>
                    <% else %>
                      <span class="text-muted">$0</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <% if @live_tournament %>
    <%# Season sub-tabs: deferred via Turbo Frame, loaded on first click %>
    <% %w[majors side_events pink_events first_half second_half].each do |tid| %>
      <turbo-frame id="tab-<%= tid %>"
                   class="tab-pane fade <%= 'show active' if @initial_tab == tid %>"
                   role="tabpanel"
                   data-src="<%= tab_standings_path(tab: tid) %>">
        <div class="text-center py-4 text-muted" style="font-size:0.9em">Loading...</div>
      </turbo-frame>
    <% end %>

    <%# Per-tournament tabs: deferred via Turbo Frame %>
    <% @completed_tournaments.reject { |t| t.status == "in_progress" }.each do |t| %>
      <turbo-frame id="tab-t<%= t.id %>"
                   class="tab-pane fade <%= 'show active' if @initial_tab == "t#{t.id}" %>"
                   role="tabpanel"
                   data-src="<%= tab_standings_path(tab: "t#{t.id}") %>">
        <div class="text-center py-4 text-muted" style="font-size:0.9em">Loading...</div>
      </turbo-frame>
    <% end %>
  <% else %>
    <% [["majors",       @majors_standings,      "Majors"],
        ["side_events",  @side_events_standings, "High-Purse Side Pot"],
        ["pink_events",  @pink_events_standings, "Low-Purse Side Pot"],
        ["first_half",   @first_half_standings,  "1st Half"],
        ["second_half",  @second_half_standings, "2nd Half"]].each do |tid, standings, _label| %>
      <div id="tab-<%= tid %>" class="tab-pane fade <%= 'show active' if @initial_tab == tid %>" role="tabpanel">
        <%= render "season_table", standings: standings, tab_id: tid %>
      </div>
    <% end %>

    <%# --- Per-tournament tabs --- %>
    <% @tournament_data.each do |td| %>
      <%= render "tournament_pane", td: td %>
    <% end %>
  <% end %>

</div><%# .tab-content %>

<%# Sync active state across the two nav rows when switching tabs %>
<script>
  document.addEventListener('turbo:load', function() {
    var outerTabContent = document.querySelector('div.tab-content');
    var allNavBtns = document.querySelectorAll('#mainTabs [data-bs-toggle="tab"], #weekTabs [data-bs-toggle="tab"]');

    allNavBtns.forEach(function(btn) {
      // Bootstrap only searches within the same <ul> for the active item, so cross-nav
      // switching doesn't auto-deactivate the other nav's pane. Manually clear it first.
      btn.addEventListener('show.bs.tab', function() {
        outerTabContent.querySelectorAll(':scope > .tab-pane.active').forEach(function(pane) {
          pane.classList.remove('show', 'active');
        });
      });

      btn.addEventListener('shown.bs.tab', function() {
        allNavBtns.forEach(function(b) { if (b !== btn) b.classList.remove('active'); });

        // Trigger lazy load for deferred turbo-frame tabs on first click
        var pane = outerTabContent.querySelector(btn.getAttribute('data-bs-target'));
        if (pane && pane.tagName === 'TURBO-FRAME' && pane.dataset.src && !pane.getAttribute('src')) {
          pane.src = pane.dataset.src;
        }
      });
    });

    // Also trigger for any deferred turbo-frame tab that's active on initial page load
    // (e.g. user bookmarked /standings?tab=majors during a live tournament)
    outerTabContent.querySelectorAll(':scope > turbo-frame[data-src]').forEach(function(frame) {
      if (frame.classList.contains('show') && frame.classList.contains('active') && !frame.getAttribute('src')) {
        frame.src = frame.getAttribute('data-src');
      }
    });

    // Keep live_sub hidden input in sync with Pool/Field toggle
    document.querySelectorAll('.pool-field-toggle [data-bs-toggle="tab"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var input = document.getElementById("refresh-live-sub");
        if (input) input.value = btn.getAttribute('data-bs-target') === '#live-field' ? 'field' : 'pool';
      });
    });

    // Pool/Field toggle: handle switching ourselves so we don't depend on Bootstrap
    // finding the active pane (it can't, because these buttons are in .btn-group not .nav).
    // Our click handler runs before Bootstrap's delegated handler; by the time Bootstrap
    // checks, the button already has 'active' so Bootstrap returns early — no conflict.
    document.querySelectorAll('.pool-field-toggle').forEach(function(group) {
      group.querySelectorAll('[data-bs-toggle="tab"]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var target = document.querySelector(btn.getAttribute('data-bs-target'));
          if (!target) return;
          // Deactivate all sibling panes
          target.parentElement.querySelectorAll(':scope > .tab-pane').forEach(function(pane) {
            pane.classList.remove('show', 'active');
          });
          // Activate the clicked pane
          target.classList.add('show', 'active');
          // Sync button states
          group.querySelectorAll('[data-bs-toggle="tab"]').forEach(function(b) {
            b.classList.toggle('active', b === btn);
          });
        });
      });
    });
  });
</script>

<% if @last_refreshed %>
<script>
  (function() {
    var refreshedAt = <%= @last_refreshed.to_i %> * 1000;
    var cooldown = <%= StandingsController::REFRESH_COOLDOWN %>;
    function updateLabels() {
      var elapsed = (Date.now() - refreshedAt) / 1000;
      var text;
      if (elapsed < 8) {
        text = "Updated just now";
      } else if (elapsed < 60) {
        text = "Updated less than a minute ago";
      } else {
        var mins = Math.floor(elapsed / 60);
        text = "Updated " + mins + (mins === 1 ? " minute" : " minutes") + " ago";
      }
      document.querySelectorAll(".refreshed-label").forEach(function(el) { el.textContent = text; });

      // Re-enable the refresh button once cooldown has passed
      var btn = document.getElementById("refresh-btn");
      if (btn && elapsed >= cooldown) {
        btn.classList.remove("disabled");
        btn.disabled = false;
      }
    }
    updateLabels();
    setInterval(updateLabels, 1000);
  })();
</script>
<% end %>

<script>
  (function() {
    // Keep return_tab hidden input in sync with whatever tab is currently active
    function syncReturnTab() {
      var input = document.getElementById("refresh-return-tab");
      if (!input) return;
      var active = document.querySelector(".nav-tabs .nav-link.active");
      if (active && active.dataset.bsTarget) {
        input.value = active.dataset.bsTarget.replace("#tab-", "");
      }
    }
    document.addEventListener("turbo:load", function() {
      syncReturnTab();
      document.querySelectorAll(".nav-tabs .nav-link").forEach(function(tab) {
        tab.addEventListener("shown.bs.tab", syncReturnTab);
      });
    });
  })();
</script>
